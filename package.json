{
  "name": "clause-forge",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:worker\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:worker": "wrangler dev",
    "build": "npm run build --workspace=frontend",
    "typecheck": "npm run typecheck --workspace=backend && npm run build --workspace=frontend",
    "deploy": "npm run deploy:worker",
    "deploy:worker": "wrangler deploy",
    "deploy:frontend": "vercel --prod"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "wrangler": "^4.107.1"
  },
  "dependencies": {
    "monaco-editor": "^0.55.1",
    "vite": "^8.0.11"
  },
  "overrides": {
    "dompurify": "^3.4.2",
    "esbuild": "^0.25.0"
  }
}
