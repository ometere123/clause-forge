# Frontend env vars — only needed when deploying to Netlify
# During local development, no .env.local file is required

# Point to your deployed backend (Railway) — only needed on Netlify
VITE_API_URL=https://your-backend.up.railway.app
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_LOCALNET_RPC=http://localhost:4000/api
